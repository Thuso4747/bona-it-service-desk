// This is your Prisma schema file,

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//User table

//enum Role will define the users' roles
enum Role {
  CLIENT
  AGENT
  ADMIN
}

model User {
  id Int @id @default(autoincrement())
  userRef String @unique
  name String
  email String @unique
  role Role
  password String
  submittedTickets Ticket[] @relation("SubmittedTickets")
  assignedTickets Ticket[] @relation("AssignedTickets")
  resolvedTickets Ticket[] @relation("ResolvedTickets")
}

//Ticket table

//enum TicketState to define what state the ticket is in
enum TicketState{
  CREATED
  PROCESSING
  COMPLETED
}

//enum ReportType to determine what type of ticket was submitted
enum ReportType{
  SUGGESTION
  COMPLAINT
  FEEDBACK
  OTHER
}

model Ticket{
  id Int @id @default(autoincrement())
  ticketRef String @unique
  trackingToken String @unique
  title String
  reportType ReportType
  description String
  status TicketState @default(CREATED)
  creationDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  slaDeadline DateTime?
  submittedBy Int 
  submittedUser User @relation("SubmittedTickets", fields: [submittedBy], references: [id])
  assignedTo Int?
  assignedAgent User? @relation("AssignedTickets", fields: [assignedTo], references: [id])
  resolvedBy Int?
  resolvingUser User? @relation("ResolvedTickets", fields: [resolvedBy], references: [id])
 
}